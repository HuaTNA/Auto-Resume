# Local development can leave both values empty; the browser uses port 8000.

# Production: backend Vercel project URL used only by the frontend rewrite.
# Do not expose this as NEXT_PUBLIC_* when using same-origin auth cookies.
BACKEND_URL=https://auto-resume-api.vercel.app

# Optional direct API origin. Prefer leaving this unset in production so the
# same-origin Vercel rewrite is used.
NEXT_PUBLIC_API_URL=
