# Required: Anthropic API key for resume generation
ANTHROPIC_API_KEY=sk-ant-...

# Required: Secret key for signing JWT tokens
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# Optional: Adzuna job search API credentials
# Get free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Production deployment settings
# Set PRODUCTION=true when backend is behind HTTPS (enables Secure + SameSite=None cookies)
PRODUCTION=false
# Frontend URL for CORS (e.g., https://auto-resume-two.vercel.app)
VERCEL_FRONTEND_URL=
