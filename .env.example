# Required: Anthropic API key for resume generation
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required: Secret key for signing JWT tokens
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# Production: Supabase transaction pooler URL (port 6543), recommended for
# Vercel Functions. Copy it from Supabase -> Connect -> Transaction pooler.
# Keep sslmode=require for hosted Postgres.
DATABASE_URL=postgresql://postgres.example:password@host:6543/postgres?sslmode=require
# Alternatively, use separate values when the password contains URL-reserved
# characters. Leave DATABASE_URL empty when using these variables.
DB_HOST=
DB_USER=postgres.project-ref
DB_PASSWORD=
DB_PORT=6543
DB_NAME=postgres
DB_SSLMODE=require
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2

# Optional: Adzuna job search API credentials
# Get free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Production deployment settings
# Vercel proxies /api to Cloud Run, so the browser sees a first-party cookie.
PRODUCTION=true
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Exact frontend URL for CORS (e.g. https://auto-resume-two.vercel.app)
VERCEL_FRONTEND_URL=
CORS_ORIGINS=

# Public signup protection. Production defaults to invite when this is omitted.
REGISTRATION_MODE=invite
REGISTRATION_INVITE_CODE=change-me-to-a-random-invite-code
# One resume flow uses roughly 8-10 units. Limits are per process/minute and
# persisted per user/day respectively.
API_REQUESTS_PER_MINUTE=12
API_DAILY_UNITS_PER_USER=60

# Required when invoking the protected internal automation endpoint.
CRON_SECRET=change-me-to-an-independent-random-secret

# Local development runs due automations inside the API process by default.
# Set to false when using `python automation/runner.py` as a separate worker.
LOCAL_AUTOMATION_SCHEDULER=true
AUTOMATION_POLL_SECONDS=30

# OAuth integrations. Register these exact local callback URLs with providers:
# http://localhost:8000/api/integrations/notion/callback
# http://localhost:8000/api/integrations/google-calendar/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/integrations/notion/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google-calendar/callback
# Optional independent encryption secret. Falls back to JWT_SECRET when empty.
INTEGRATION_ENCRYPTION_KEY=

# Vercel's filesystem is ephemeral. Generated files are temporary; durable
# records are stored in Supabase PostgreSQL.
OUTPUT_DIR=/tmp/auto-resume-output
