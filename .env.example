# Required: Anthropic API key for resume generation
ANTHROPIC_API_KEY=sk-ant-...

# Required: Secret key for signing JWT tokens
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# Production: persistent PostgreSQL connection string (Supabase pooler URL).
# Keep sslmode=require for hosted Postgres.
DATABASE_URL=postgresql://postgres.example:password@host:5432/postgres?sslmode=require

# Optional: Adzuna job search API credentials
# Get free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Production deployment settings
# Vercel proxies /api to Cloud Run, so the browser sees a first-party cookie.
PRODUCTION=true
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Exact frontend URL for CORS (e.g. https://auto-resume-two.vercel.app)
VERCEL_FRONTEND_URL=
CORS_ORIGINS=

# Required by Cloud Scheduler when invoking the internal automation endpoint.
CRON_SECRET=change-me-to-an-independent-random-secret

# Cloud Run's filesystem is ephemeral. Generated files are temporary; durable
# records are stored in PostgreSQL.
OUTPUT_DIR=/tmp/auto-resume-output
